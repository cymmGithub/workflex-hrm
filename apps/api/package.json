{
  "name": "@workflex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "migrate": "node-pg-migrate up -j ts -m src/db/migrations",
    "migrate:create": "node-pg-migrate create -j ts -m src/db/migrations"
  },
  "dependencies": {},
  "devDependencies": {}
}
