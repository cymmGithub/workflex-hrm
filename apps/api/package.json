{
  "name": "@workflex/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "migrate": "NODE_OPTIONS='--import tsx' node-pg-migrate up -m src/db/migrations -j ts --envPath .env",
    "migrate:down": "NODE_OPTIONS='--import tsx' node-pg-migrate down -m src/db/migrations -j ts --envPath .env",
    "migrate:create": "node-pg-migrate create -m src/db/migrations -j ts",
    "seed": "node --env-file=.env --import tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/postgres": "^6.0.2",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@sinclair/typebox": "^0.34.49",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
