# --- Database (Neon Postgres) ---
# Local dev points at a Neon *dev branch*; the live demo uses the main/prod branch (design D11).
# Copy to .env and fill in your Neon connection string.
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# --- Server ---
# Port Fastify listens on.
# IMPORTANT on mikr.us: this MUST be the port assigned to your VPS — the auto-subdomain
# and automatic SSL (Cytrus) are bound to that specific port (design D1).
PORT=3000
